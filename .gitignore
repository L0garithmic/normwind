# npm pack artefacts — never commit tarballs
*.tgz

# local env / secrets
.env
.env.*
*.npmrc

# OS / editor
.DS_Store
Thumbs.db
.vscode/

# dependencies
node_modules/

# scratch / tooling sandboxes
.tmp/
.venv/
.saydeploy/

# regression-harness scratch output (only emitted when a fixture diverges)
test/fixtures/**/actual.*

# editor / refactor backups
*.bak

# Generated agent code map (local artifact; rebuild with ~/.claude/tools/codemap.py)
.claude/codemap/
