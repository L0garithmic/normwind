{
  "name": "@lunawerx/normwind",
  "version": "3.5.1",
  "description": "Normalize Tailwinds: Tailwind shorthand audit, canonicalization checks, and safe autofix",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LunarWerxs/NormWind.git"
  },
  "homepage": "https://github.com/LunarWerxs/NormWind",
  "bugs": {
    "url": "https://github.com/LunarWerxs/NormWind/issues"
  },
  "bin": {
    "normwind": "bin/normwind.mjs",
    "normwinds": "bin/normwind.mjs"
  },
  "files": [
    "bin/normwind.mjs",
    "docs/reference/canonical-replacements.json",
    "docs/reference/canonical-replacements.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "canonical:extract": "node bin/normwind.mjs --extract-canonical --write-canonical-files",
    "canonical:check": "node bin/normwind.mjs --check-canonical",
    "test": "node scripts/test-prepush.mjs",
    "prepush": "node scripts/test-prepush.mjs",
    "test:regression": "node scripts/test-regression.mjs",
    "test:regression:update": "node scripts/test-regression.mjs --update",
    "test:compare": "node scripts/test-compare.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "tailwind",
    "tailwindcss",
    "eslint",
    "lint",
    "cli",
    "shorthand",
    "canonicalization",
    "autofix",
    "codemod",
    "vue",
    "react",
    "typescript",
    "utility-classes",
    "class-normalization"
  ],
  "dependencies": {
    "@babel/parser": "7.29.7",
    "eslint-plugin-tailwindcss": "3.18.3",
    "tailwindcss": "4.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
